{
  "name": "hopdrive-eventkit",
  "version": "0.5.0",
  "description": "Source-agnostic business-event execution framework. The successor to @hopdrive/hasura-event-detector.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/esm/core/index.d.ts",
        "default": "./dist/esm/core/index.js"
      },
      "require": {
        "types": "./dist/cjs/core/index.d.ts",
        "default": "./dist/cjs/core/index.js"
      }
    },
    "./sources": {
      "import": {
        "types": "./dist/esm/plugins/sources.d.ts",
        "default": "./dist/esm/plugins/sources.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/sources.d.ts",
        "default": "./dist/cjs/plugins/sources.js"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/esm/plugins/index.d.ts",
        "default": "./dist/esm/plugins/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/index.d.ts",
        "default": "./dist/cjs/plugins/index.js"
      }
    },
    "./sources/hasura": {
      "import": {
        "types": "./dist/esm/plugins/source-hasura.d.ts",
        "default": "./dist/esm/plugins/source-hasura.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/source-hasura.d.ts",
        "default": "./dist/cjs/plugins/source-hasura.js"
      }
    },
    "./sources/webhook": {
      "import": {
        "types": "./dist/esm/plugins/source-webhook/index.d.ts",
        "default": "./dist/esm/plugins/source-webhook/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/source-webhook/index.d.ts",
        "default": "./dist/cjs/plugins/source-webhook/index.js"
      }
    },
    "./plugins/batch": {
      "import": {
        "types": "./dist/esm/plugins/batch/index.d.ts",
        "default": "./dist/esm/plugins/batch/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/batch/index.d.ts",
        "default": "./dist/cjs/plugins/batch/index.js"
      }
    },
    "./plugins/observability": {
      "import": {
        "types": "./dist/esm/plugins/observability/index.d.ts",
        "default": "./dist/esm/plugins/observability/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/observability/index.d.ts",
        "default": "./dist/cjs/plugins/observability/index.js"
      }
    },
    "./plugins/observability/graphql-sink": {
      "import": {
        "types": "./dist/esm/plugins/observability/graphql-sink.d.ts",
        "default": "./dist/esm/plugins/observability/graphql-sink.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/observability/graphql-sink.d.ts",
        "default": "./dist/cjs/plugins/observability/graphql-sink.js"
      }
    },
    "./plugins/loop-guard": {
      "import": {
        "types": "./dist/esm/plugins/loop-guard/index.d.ts",
        "default": "./dist/esm/plugins/loop-guard/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/loop-guard/index.d.ts",
        "default": "./dist/cjs/plugins/loop-guard/index.js"
      }
    },
    "./plugins/correlation-resolver": {
      "import": {
        "types": "./dist/esm/plugins/correlation-resolver/index.d.ts",
        "default": "./dist/esm/plugins/correlation-resolver/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/correlation-resolver/index.d.ts",
        "default": "./dist/cjs/plugins/correlation-resolver/index.js"
      }
    },
    "./plugins/transports/grafana": {
      "import": {
        "types": "./dist/esm/plugins/grafana/index.d.ts",
        "default": "./dist/esm/plugins/grafana/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/grafana/index.d.ts",
        "default": "./dist/cjs/plugins/grafana/index.js"
      }
    },
    "./plugins/transports/sentry": {
      "import": {
        "types": "./dist/esm/plugins/sentry/index.d.ts",
        "default": "./dist/esm/plugins/sentry/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/sentry/index.d.ts",
        "default": "./dist/cjs/plugins/sentry/index.js"
      }
    },
    "./platforms": {
      "import": {
        "types": "./dist/esm/plugins/platforms.d.ts",
        "default": "./dist/esm/plugins/platforms.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/platforms.d.ts",
        "default": "./dist/cjs/plugins/platforms.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/esm/testing/index.d.ts",
        "default": "./dist/esm/testing/index.js"
      },
      "require": {
        "types": "./dist/cjs/testing/index.d.ts",
        "default": "./dist/cjs/testing/index.js"
      }
    },
    "./flow": {
      "import": {
        "types": "./dist/esm/flow/index.d.ts",
        "default": "./dist/esm/flow/index.js"
      },
      "require": {
        "types": "./dist/cjs/flow/index.d.ts",
        "default": "./dist/cjs/flow/index.js"
      }
    },
    "./console": {
      "import": {
        "types": "./dist/console/index.d.ts",
        "default": "./dist/console/index.js"
      }
    },
    "./console/style.css": "./dist/console/style.css"
  },
  "bin": {
    "eventkit-flow": "bin/eventkit-flow.mjs"
  },
  "files": [
    "dist",
    "bin",
    "docs/guide.html",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "node scripts/build.cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:contracts": "tsc -p tsconfig.typetest.json",
    "smoke:bundle": "node scripts/bundle-smoke.cjs",
    "build:console": "npm --prefix console ci && npm --prefix console run build:lib",
    "docs": "typedoc",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version && npm install --package-lock-only --ignore-scripts",
    "release": "npm run build && npm run smoke:bundle && npm run build:console && changeset publish",
    "prepare": "npm run build",
    "attw": "attw --pack . --profile node16",
    "test:coverage": "vitest run --coverage",
    "docs:compile": "node scripts/docs-compile.cjs",
    "mutation": "stryker run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopdrive/eventkit.git"
  },
  "author": "HopDrive Engineering",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {},
  "comment:peerDependencies": "UI libs for the hopdrive-eventkit/console subpath ONLY. All optional (peerDependenciesMeta) so a server/library consumer of the core never installs them — modern npm auto-installs non-optional peers. The create-eventkit-console wrapper template lists these as real dependencies, which is how a console host actually gets them.",
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "@apollo/client": "^3.8.0",
    "graphql": "^16.8.0",
    "antd": "^5.10.0",
    "@ant-design/icons": "^5.2.0",
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.0.0",
    "@tanstack/react-table": "^8.10.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@microlink/react-json-view": "^1.31.21",
    "framer-motion": "^10.16.0",
    "recharts": "^2.9.0",
    "reactflow": "^11.10.0",
    "jsondiffpatch": "^0.7.2",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "yaml": "^2.9.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "react-router-dom": { "optional": true },
    "@apollo/client": { "optional": true },
    "graphql": { "optional": true },
    "antd": { "optional": true },
    "@ant-design/icons": { "optional": true },
    "@headlessui/react": { "optional": true },
    "@heroicons/react": { "optional": true },
    "@tanstack/react-table": { "optional": true },
    "@tanstack/react-virtual": { "optional": true },
    "@microlink/react-json-view": { "optional": true },
    "framer-motion": { "optional": true },
    "recharts": { "optional": true },
    "reactflow": { "optional": true },
    "jsondiffpatch": { "optional": true },
    "date-fns": { "optional": true },
    "clsx": { "optional": true },
    "yaml": { "optional": true }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.27.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^20.11.19",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "fast-check": "^3.23.2",
    "rimraf": "^5.0.5",
    "typedoc": "^0.26.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
