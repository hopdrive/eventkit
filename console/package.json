{
  "name": "@hopdrive/eventkit-console",
  "version": "0.1.0",
  "description": "Observability console UI for EventKit",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "@apollo/client": "^3.8.0",
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.0.0",
    "@microlink/react-json-view": "^1.31.21",
    "@tanstack/react-table": "^8.10.0",
    "@tanstack/react-virtual": "^3.0.0",
    "antd": "^5.10.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.0",
    "graphql": "^16.8.0",
    "jsondiffpatch": "^0.7.2",
    "open": "^8.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "reactflow": "^11.10.0",
    "recharts": "^2.9.0",
    "tailwindcss": "^3.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/introspection": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@netlify/functions": "^2.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.2.2",
    "postcss": "^8.4.0",
    "puppeteer": "25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.0",
    "vite": "^8.1.3"
  },
  "scripts": {
    "start": "node node_modules/vite/bin/vite.js",
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "build:lib": "npm run build:lib:js && npm run build:lib:types",
    "build:lib:js": "node node_modules/vite/bin/vite.js build --config vite.lib.config.ts",
    "build:lib:types": "node node_modules/typescript/bin/tsc -p tsconfig.lib.json; test -s ../dist/console/index.d.ts && test -s ../dist/console/config.d.ts && test -s ../dist/console/EventKitConsole.d.ts",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "seed": "node db/seed/seed.mjs",
    "db:setup": "node db/local-setup.mjs",
    "perf": "node perf/measure.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopdrive/eventkit.git",
    "directory": "console"
  },
  "keywords": [
    "hasura",
    "eventkit",
    "observability",
    "console",
    "ui",
    "dashboard"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  }
}
